rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      // Admins are users whose uid has an entry in roles_admin/{uid}
      // (No hardcoded bypasses).
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Grant absolute power to administrators across the entire document tree
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid;
      allow update: if (isOwner(userId) || isAdmin())
        && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();

      // Cart Persistence
      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }

      // Favorites Persistence
      match /favorites/{productId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Crops Collection
    match /crops/{cropId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.farmerId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.farmerId == request.auth.uid
        && request.resource.data.farmerId == resource.data.farmerId
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.farmerId == request.auth.uid);
    }

    // 3. Orders Collection
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && (resource.data.customerId == request.auth.uid || resource.data.farmerId == request.auth.uid))
      );
      
      // Farmer can update order status — but ONLY one step forward in sequence.
      // Prevents jumping from pending → delivered directly.
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.farmerId == request.auth.uid
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.farmerId == resource.data.farmerId
        && (
          // pending → confirmed
          (resource.data.status == 'pending'   && request.resource.data.status == 'confirmed')
          // confirmed → shipped
          || (resource.data.status == 'confirmed' && request.resource.data.status == 'shipped')
          // shipped → delivered
          || (resource.data.status == 'shipped'   && request.resource.data.status == 'delivered')
        )
      );
      allow delete: if isAdmin();
    }

    // 4. Admin & Market Data
    match /market_rates/{rateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Market Demands (consumer crop requests)
    match /market_demands/{demandId} {
      // Any signed-in user can read (farmers browse open demands, consumers see their own)
      allow read: if isSignedIn();
      // Only consumers can create their own demand
      allow create: if isSignedIn()
        && request.resource.data.consumerId == request.auth.uid
        && request.resource.data.quantityKg is number
        && request.resource.data.quantityKg > 0
        && request.resource.data.quantityKg <= 50;

      allow update: if isAdmin()
        // ── Consumer updates their own open demand (edit/delete before offer) ──
        || (
          isSignedIn()
          && resource.data.consumerId == request.auth.uid
          && request.resource.data.consumerId == resource.data.consumerId
          // Consumer cannot change committedFarmerId once a farmer is attached
          && request.resource.data.committedFarmerId == resource.data.committedFarmerId
        )
        // ── Farmer submits a NEW offer on an open demand ──
        || (
          isSignedIn()
          && resource.data.status == 'open'
          && request.resource.data.status == 'quoted'
          && request.resource.data.consumerId == resource.data.consumerId
          && request.resource.data.committedFarmerId == request.auth.uid
        )
        // ── Farmer updates their own QUOTED offer (price edit allowed; status cannot change) ──
        || (
          isSignedIn()
          && resource.data.committedFarmerId == request.auth.uid
          && resource.data.status == 'quoted'
          && request.resource.data.status == 'quoted'
          && request.resource.data.consumerId == resource.data.consumerId
          && request.resource.data.committedFarmerId == resource.data.committedFarmerId
          // Only allow editing the offer fields while quoted
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'farmerOfferPrice',
            'farmerOfferDisplay',
            'farmerOfferUnit',
            'farmerOfferOrganic',
            'farmerAvailableUntil',
            'updatedAt'
          ])
        )
        // ── Farmer withdraws their own QUOTED offer (reset demand to open) ──
        || (
          isSignedIn()
          && resource.data.committedFarmerId == request.auth.uid
          && resource.data.status == 'quoted'
          && request.resource.data.status == 'open'
          && request.resource.data.consumerId == resource.data.consumerId
          && request.resource.data.committedFarmerId == null
          // Only allow clearing offer/commit fields + status
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'committedFarmerId',
            'committedFarmerName',
            'farmerOfferPrice',
            'farmerOfferDisplay',
            'farmerOfferUnit',
            'farmerOfferOrganic',
            'farmerAvailableUntil',
            'farmerPhone',
            'quotedAt',
            'updatedAt'
          ])
        )
        // ── Farmer advances status AFTER deal is closed (dispatch flow) ──
        // Price fields are LOCKED once deal_closed — prevents price manipulation
        || (
          isSignedIn()
          && resource.data.committedFarmerId == request.auth.uid
          && resource.data.status != 'open'
          && resource.data.status != 'quoted'
          // Lock price fields after deal is accepted
          && request.resource.data.farmerOfferPrice == resource.data.farmerOfferPrice
          && request.resource.data.farmerOfferDisplay == resource.data.farmerOfferDisplay
          && request.resource.data.farmerOfferUnit == resource.data.farmerOfferUnit
          && request.resource.data.consumerId == resource.data.consumerId
          && request.resource.data.committedFarmerId == resource.data.committedFarmerId
          // Allowed status transitions: deal_closed→in_progress only
          && (
            resource.data.status == 'deal_closed' && request.resource.data.status == 'in_progress'
            || resource.data.status == request.resource.data.status
          )
        );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.consumerId == request.auth.uid);

      // ── Chat Messages Subcollection ──
      // Read : any signed-in user (demand itself is already public to all farmers)
      // Create: must be the sender, must include expiresAt for Firestore TTL auto-delete
      // Update/Delete: immutable once sent
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.expiresAt is timestamp;
        allow update: if false;
        allow delete: if false;
      }
    }

    // 6. Complaints
    match /complaints/{complaintId} {
      // Any signed-in user can file a complaint (create)
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      // Reporter can read their own complaints; admin can read all
      allow read: if isAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      // Only admin can update (change status: open → reviewed → resolved)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 7. Reviews
    match /reviews/{reviewId} {
      // Only the consumer who made the deal can submit a review
      // AND only if the demand hasn't already been reviewed (prevents spam)
      allow create: if isSignedIn()
        && request.resource.data.consumerId == request.auth.uid
        && request.resource.data.demandId is string
        && !get(/databases/$(database)/documents/market_demands/$(request.resource.data.demandId)).data.reviewed;
      // Public read so homepage can display original user reviews
      allow read: if true;
      // Admin-only updates/deletes (moderation)
      allow update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      // Only existing admins can grant/revoke admin access
      allow write: if isAdmin();
    }

    // Profile Photos
    match /profile_photos/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // 8. Resource Tools (farming equipment listed for rent)
    match /resource_tools/{toolId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // 9. Resource Requests (tool rental requests posted by users)
    match /resource_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
      // Only the requester themselves can update their own request (immutable requesterId)
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.requesterId == request.auth.uid
            && request.resource.data.requesterId == resource.data.requesterId);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.requesterId == request.auth.uid);
    }

    // 10. Rental Requests (used by ResourceSharePage / FarmerDashboard / App notifications)
    match /rental_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.requesterId == request.auth.uid)
        || (isSignedIn() && resource.data.toolOwnerId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.requesterId == request.auth.uid);
    }

    // 11. Resource Reports (complaints for rental flows)
    match /resource_reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}

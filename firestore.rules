rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'eagletheegala@gmail.com'
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      // Cart Persistence
      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Crops Collection
    match /crops/{cropId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.farmerId == request.auth.uid);
    }

    // 3. Orders Collection
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && (resource.data.customerId == request.auth.uid || resource.data.farmerId == request.auth.uid))
      );
      
      allow update: if isAdmin() || (isSignedIn() && resource.data.farmerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 4. Admin & Market Data
    match /market_rates/{rateId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
